# =============================================================================
# BACKEND ENVIRONMENT EXAMPLE
# Copy this file to .env and fill in your actual values
# NEVER commit .env — it contains secrets
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
# Get this from: MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/letsfixcampus

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRE=7d

# ── College Settings ──────────────────────────────────────────────────────────
COLLEGE_EMAIL_DOMAIN=@grietcollege.com

# ── Image Uploads (Cloudinary) ────────────────────────────────────────────────
# Set to 'cloudinary' for production, 'local' for development
UPLOAD_METHOD=cloudinary

# Get these from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (e.g. https://letsfixcampus.vercel.app)
FRONTEND_URL=https://YOUR-APP.vercel.app

# ── Poll Automation ───────────────────────────────────────────────────────────
# Day of week for weekly poll (0=Sunday, 6=Saturday)
POLL_DAY=6
POLL_START_HOUR=0
